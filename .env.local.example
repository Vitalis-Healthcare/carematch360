# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AxisCare integration
AXISCARE_SITE_NUMBER=your_site_number
AXISCARE_API_TOKEN=your_bearer_token

# Phase 2 — Email dispatch (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=dispatch@carematch360.com

# Phase 2 — SMS dispatch (Vonage)
# Get these from dashboard.nexmo.com → API Settings
VONAGE_API_KEY=xxxxxxxx
VONAGE_API_SECRET=xxxxxxxxxxxxxxxxxxxx
VONAGE_FROM_NUMBER=CareMatch360  # or a Vonage virtual number you purchase

# App URL (used in response links)
NEXT_PUBLIC_APP_URL=https://carematch360.vercel.app
-e 
# Coordinator email — receives alerts when providers click 'I Have Questions'
COORDINATOR_EMAIL=okezie@vitalis.com
